            <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler - Using Milliseconds" enabled="false">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.util.Random

// Function to generate a random string of specified length from given characters
String generateRandomString(int length, String charSet) {
    Random random = new Random()
    StringBuilder sb = new StringBuilder(length)
    for (int i = 0; i &lt; length; i++) {
        sb.append(charSet.charAt(random.nextInt(charSet.length())))
    }
    return sb.toString()
}

// Define the characters that might be part of the result
String chars = &apos;abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789&apos;

// Get current time in milliseconds
String timestamp = System.currentTimeMillis().toString()

// Always take the last 5 digits of the timestamp; if less than 5 digits, pad with zeros (rare case)
String reducedTimestamp = timestamp.length() &gt; 5 ? timestamp.substring(timestamp.length() - 5) : String.format(&quot;%05d&quot;, Integer.parseInt(timestamp))

// Calculate how many characters are needed to complete the 12 character string
int neededChars = 12 - reducedTimestamp.length()

// Generate the remaining random characters
String randomChars = generateRandomString(neededChars, chars)

// Combine them to form the final string
String finalString = reducedTimestamp + randomChars

// Ensure the final string is exactly 12 characters long
if (finalString.length() &gt; 12) {
    finalString = finalString.substring(0, 12)
} else if (finalString.length() &lt; 12) {
    // Add additional random characters if under 12 (should not normally happen with above logic)
    finalString += generateRandomString(12 - finalString.length(), chars)
}

// Store the final string in a JMeter variable to use later in the test
vars.put(&quot;10_Fund_Transfer_TRTR&quot;, finalString)
</stringProp>
            </JSR223Sampler>
