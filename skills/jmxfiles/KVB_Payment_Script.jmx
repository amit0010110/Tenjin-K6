&quot;&quot;&quot;;

// Replace Placeholders with Variables
String finalRequest = xmlRequest
        .replace(&quot;${BizMsgIdr}&quot;, bizMsgIdr)
        .replace(&quot;${TxId}&quot;, txId)
        .replace(&quot;${EndToEndId}&quot;, endToEndId)
        .replace(&quot;${DbtrAcct}&quot;, dbtrAcct);
   log.info(&quot;Message successfully put into queue: &quot; + finalRequest);
// IBM MQ Integration
MQEnvironment.hostname = HOST_NAME;
MQEnvironment.port = PORT;
MQEnvironment.channel = CHANNEL;
MQEnvironment.sslCipherSuite = &quot;&quot;;

MQQueueManager queueMgr = null;
MQQueue putQueue = null;

try {
    // Connect to the Queue Manager
    queueMgr = new MQQueueManager(QMGR);
    log.info(&quot;Connected to Queue Manager: &quot; + QMGR);

    // Access the Put Queue
    putQueue = queueMgr.accessQueue(RTGS_PUT_QUEUE_NAME, MQC.MQOO_FAIL_IF_QUIESCING | MQC.MQOO_OUTPUT);

    // Prepare MQ Message
    MQPutMessageOptions pmo = new MQPutMessageOptions();
    MQMessage reqMessage = new MQMessage();
    reqMessage.replyToQueueName = RTGS_GET_QUEUE_NAME;
    reqMessage.report = MQC.MQRO_PASS_MSG_ID;
    reqMessage.messageType = MQC.MQMT_REQUEST;
    reqMessage.write(finalRequest.getBytes());

    // Put Message in Queue
    putQueue.put(reqMessage, pmo);
    log.info(&quot;Message successfully put into queue: &quot; + RTGS_PUT_QUEUE_NAME);
    log.info(&quot;Message successfully put into queue: &quot; + reqMessage);

} catch (MQException e) {
    log.error(&quot;MQException: &quot; + e.getMessage());
    e.printStackTrace();
} catch (IOException e) {
    log.error(&quot;IOException: &quot; + e.getMessage());
    e.printStackTrace();
} finally {
    try {
        if (putQueue != null) putQueue.close();
        if (queueMgr != null) queueMgr.close();
    } catch (Exception e) {
        log.error(&quot;Cleanup Exception: &quot; + e.getMessage());
    }
}
