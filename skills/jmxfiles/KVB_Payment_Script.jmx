// Generate Dynamic Variables
String bizMsgIdr = vars.get(&quot;BizMsgIdr&quot;); // Generate unique BizMsgIdr
String txId = vars.get(&quot;TxId&quot;); // Generate unique TxId
String endToEndId = vars.get(&quot;EndToEndId&quot;); // Generate unique TxId
String dbtrAcct = vars.get(&quot;DbtrAcct&quot;); // Example debtor account number, you can generate if needed

// Save Variables for Reuse
